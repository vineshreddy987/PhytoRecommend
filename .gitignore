# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────
venv/
env/
.venv/
.env

# ── Intermediate split data (regenerated by pipeline) ─────────────────
split_data/
split_data_balanced/
split_data_v2/

# ── Large raw data files ──────────────────────────────────────────────
data/*.xlsx
data/*.zip
*.xlsx
*.zip

# ── Numpy arrays ──────────────────────────────────────────────────────
*.npy

# ── Do NOT ignore model pkl files — needed for deployment ─────────────
# models/**/*.pkl  <-- intentionally NOT ignored

# ── IDE / OS ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────
*.log
